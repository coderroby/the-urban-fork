    {
      "id": "about",
      "route": "/about",
      "template": "AboutPage",
      "seo": {
        "title": {
          "en": "About Us",
          "fr": "À Propos"
        },
        "description": {
          "en": "Learn about The Urban Fork, our food philosophy, kitchen team, and hospitality story.",
          "fr": "Découvrez notre philosophie culinaire, notre équipe et notre parcours."
        },
        "canonical": "/about",
        "ogImage": "/images/seo/about-og.jpg"
      },
      "sections": {
        "hero": {
          "title": {
            "en": "Our Story",
            "fr": "Notre Histoire"
          },
          "subtitle": {
            "en": "A restaurant built around comfort, craft, and community.",
            "fr": "Un restaurant bâti sur le confort, le savoir-faire et la communauté."
          },
          "image": {
            "src": "/images/about/restaurant-team.jpg",
            "alt": {
              "en": "The Urban Fork restaurant team",
              "fr": "L'équipe de La Fourchette Urbaine"
            }
          }
        },
        "story": {
          "title": {
            "en": "Inspired by simple food done beautifully.",
            "fr": "Inspiré par une cuisine simple et magnifiquement exécutée."
          },
          "content": [
            {
              "en": "The Urban Fork started with one idea: create a place where people can slow down, share good food, and feel at home.",
              "fr": "La Fourchette Urbaine est née d'une idée : créer un lieu où l'on peut ralentir, savourer de bons petits plats et se sentir comme chez soi."
            },
            {
              "en": "Our menu changes with the seasons and focuses on fresh produce, quality proteins, house-made sauces, and thoughtful details.",
              "fr": "Notre menu évolue au gré des saisons et met à l'honneur les produits frais, les protéines de qualité et les sauces faites maison."
            }
          ]
        },
        "values": [
          {
            "title": {
              "en": "Fresh Ingredients",
              "fr": "Ingrédients Frais"
            },
            "description": {
              "en": "We work with trusted suppliers and seasonal produce whenever possible.",
              "fr": "Nous collaborons avec des producteurs de confiance pour de savoureux produits de saison."
            }
          },
          {
            "title": {
              "en": "Warm Hospitality",
              "fr": "Hospitalité Chaleureuse"
            },
            "description": {
              "en": "From your first greeting to your final bite, we want every visit to feel personal.",
              "fr": "Dès votre arrivée et jusqu'au dessert, nous voulons que chaque instant soit mémorable."
            }
          },
          {
            "title": {
              "en": "Crafted Experience",
              "fr": "Expérience Soignée"
            },
            "description": {
              "en": "Food, drinks, music, lighting, and service all work together to create the right mood.",
              "fr": "Les plats, les boissons, la musique et le service s'accordent pour sublimer l'ambiance."
            }
          }
        ]
      }
    },
